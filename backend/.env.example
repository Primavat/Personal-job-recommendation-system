# Backend environment variables

# ── Supabase Configuration ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
DATABASE_URL=postgresql://user:password@localhost:5432/job_recommendations
JWT_SECRET=your-jwt-secret-key

# ── AI Backend (groq/gemini/claude/openrouter) ─────────────────────
AI_BACKEND=groq
AI_API_KEY=your_key_here
AI_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=your_anthropic_key

# ── Job APIs Configuration ──────────────────────────────────────────
FINDWORK_API_KEY=optional_findwork_key

# ── Google Sheets (optional, for data export) ──────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_NAME=Global Tech Jobs Pipeline
GOOGLE_SHEET_EMAIL=your_email@gmail.com

# ── Telegram Notifications (optional) ───────────────────────────────
TELEGRAM_BOT_TOKEN=optional_bot_token
TELEGRAM_CHAT_ID=optional_chat_id

# ── FastAPI Configuration ──────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True
