# Backend API URL (set this to your deployed backend URL)
# If not set, the app will run in demo mode with mock data
NEXT_PUBLIC_API_URL=http://localhost:8000

# Demo mode (set to 'true' to force demo mode even if API_URL is set)
NEXT_PUBLIC_DEMO_MODE=false

# Supabase (optional, for database features)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
